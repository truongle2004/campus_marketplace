PORT=8080
APP_ENV=local
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=campus_marketplace
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=campus-marketplace
MINIO_USE_SSL=false
# Clerk session JWT verification (Dashboard → API Keys → Advanced → JWT public key / JWKS)
# JWKS: https://<your-clerk-domain>/.well-known/jwks.json
CLERK_JWKS_URL=
# Issuer: https://<your-clerk-domain>
CLERK_ISSUER=
# Optional comma-separated frontend origins (validates JWT azp claim)
CLERK_AUTHORIZED_PARTIES=http://localhost:5173
