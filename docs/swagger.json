                        "schema": {
                            "$ref": "#/definitions/github_com_truongle2004_campus_marketplace_pkg_respond.ErrorBody"
                        }
                    }
                }
            },
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "tags": [
                    "users"
                ],
                "summary": "Deactivate own account",
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_truongle2004_campus_marketplace_pkg_respond.ErrorBody"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/github_com_truongle2004_campus_marketplace_pkg_respond.ErrorBody"
